generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  WORKER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Garden {
  id           String    @id @default(uuid())
  name         String
  location     String
  ownerName    String
  ownerContact String
  leaseAmount  Float
  startDate    DateTime
  endDate      DateTime
  treeCount    Int
  variety      String
  notes        String?
  expenses     Expense[]
  harvests     Harvest[]
  sales        Sale[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  contact   String
  type      String
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Expense {
  id         String   @id @default(uuid())
  gardenId   String
  garden     Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  type       String
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  cost       Float
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Harvest {
  id        String   @id @default(uuid())
  gardenId  String
  garden    Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  date      DateTime
  quantity  Float
  laborCost Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id            String   @id @default(uuid())
  buyerName     String
  location      String
  gardenId      String
  garden        Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  quantity      Float
  pricePerUnit  Float
  transportCost Float
  date          DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
